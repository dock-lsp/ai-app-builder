# 环境变量配置
# 复制此文件为 .env 并填入实际值

# JWT 密钥（必须修改！）
JWT_SECRET=your-random-secret-key-here

# DeepSeek API Key（可选）
DEEPSEEK_API_KEY=

# 服务器端口
PORT=3001

# 数据库连接（生产环境建议替换为 PostgreSQL/MongoDB）
# DATABASE_URL=postgresql://user:password@localhost:5432/aiappbuilder

# Redis（用于缓存和会话）
# REDIS_URL=redis://localhost:6379

# 域名
DOMAIN=your-domain.com

# ==================== 邮件服务配置（二选一）====================

# 【方案1】Gmail SMTP（免费500封/天）
# 需要开启两步验证后创建应用密码
# EMAIL_PROVIDER=gmail
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_PASS=your-gmail-app-password

# 【方案2】Resend（推荐！免费3000封/月）
# 注册地址：https://resend.com
# 1. 注册后获取 API Key
# 2. 在 Resend 控制台验证你的域名（或使用 resend.com 默认域名）
# 3. 填入 EMAIL_FROM（必须是你在 Resend 验证过的邮箱或默认域名邮箱）
EMAIL_PROVIDER=resend
EMAIL_API_KEY=your-resend-api-key
EMAIL_FROM=onboarding@resend.dev

# 如果不配置任何邮件服务，注册时将跳过邮箱验证码验证
